# Solution-wide ignores
.vs/
*.log
*.tmp
*.bak
Thumbs.db
.DS_Store

# ChoirAdminApp project artifacts
ChoirAdminApp/bin/
ChoirAdminApp/obj/
ChoirAdminApp/publish/

# IDE & tooling
.vscode/
.idea/

# User secrets & configs
ChoirAdminApp/secrets.json
ChoirAdminApp/appsettings.Development.json
ChoirAdminApp/appsettings.Local.json
ChoirAdminApp/appsettings.*.json
